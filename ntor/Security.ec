  proc; inline.
  sp; if => //.
  sp; if => //.
  match = => //.
  + auto => />.
  move => st.
  match = => //.
  + auto => />.
  + move => s t k ir.
    if => //; 2: by auto => />.
    rcondf {1} ^if. auto => />.
    rcondf {2} ^if. auto => />.
    sp 3 3; if {2} => //.
    + sp; seq 1 1: (#pre /\ ={ks2}); 1: by auto => />.
      if => //.
      + auto => |> &2 17? inv *. do split; ~6: smt(get_setE mem_set).
