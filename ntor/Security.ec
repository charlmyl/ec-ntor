    smt(c_eq_fresh_ck c_eq_have_p_ck).
  if => //.
  + auto => />.
    smt(get_setE).
  auto => />.
  smt(get_setE).

- proc; inline.
  sp; if => //.
  sp; if => //. sp; match => //.
  + smt().
  + smt().
  move => stl str.
  match => //; 1..3: smt().
