        /\ Game4.b0{1} /\ !Game5Ltk.test_ltkrev{2}
        /\ (forall i s pt ir, i \in Game4.c_smap => Game4.c_smap.[i] = Some (Pending_mod s pt ir) => !ir.`3){1}
        /\ (forall b j, Game4.tested = None => (b, j) \in Game4.s_smap => !get_ir_test (oget Game4.s_smap.[(b,j)])){1}
        /\ (forall i, Game4.tested = None => i \in Game4.c_smap => !get_ir_test (oget Game4.c_smap.[i])){1}
        /\ (forall b1 b2 j1 j2, (b1, j1) \in Game4.s_smap => (b2, j2) \in Game4.s_smap => get_ir_test (oget Game4.s_smap.[(b1, j1)])
             => get_ir_test (oget Game4.s_smap.[(b2, j2)]) => (b1, j1) = (b2, j2)){1}
        /\ (forall i1 i2, i1 \in Game4.c_smap => i2 \in Game4.c_smap => get_ir_test (oget Game4.c_smap.[i1]) 
             => get_ir_test (oget Game4.c_smap.[i2]) => i1 = i2){1}
        /\ (forall b j i, (b, j) \in Game4.s_smap => i \in Game4.c_smap => get_ir_test (oget Game4.c_smap.[i]) => !get_ir_test (oget Game4.s_smap.[(b, j)])){1}
    ) Game4_inv_c_test' => // [/#|].
  proc; inline.
  sp; if => //.
  sp; if => //.
  match = => //.
  + auto => />.
  move => st.
  match = => //.
  + auto => />.
  + move => s t k ir.
    if => //; 2: by auto => />.
    rcondf {1} ^if. auto => />.
    rcondf {2} ^if. auto => />.
    sp 3 3; if {2} => //.
    + sp; seq 1 1: (#pre /\ ={ks2}); 1: by auto => />.
      if => //.
      + auto => |> &2 *. smt(get_setE mem_set).
      auto => |> &2 *. smt(get_setE mem_set).
    auto => |> &2 *. 
  auto => />.
- move => &2 bad.
  proc; sp; if => //.
  rcondf ^if. auto => />.
  auto => />.
- move => &1.
  proc; inline.
  rcondf ^if; auto => />.

(* s_test *)
- conseq (: ={arg} /\ ={b0, hm, h1m, h2m, c_smap, s_smap, servers, tested, b_set, x_set, y_set, pk_set, m1_set, m2_set, bad1, bad2, bad3, tq, 
                           hq, badq, test_ephrev_s, test_ltkrev, comp_tag}(Game4, Game5Ltk)
        /\ Game4.b0{1} /\ !Game5Ltk.test_ltkrev{2}
        /\ (forall i s pt ir, i \in Game4.c_smap => Game4.c_smap.[i] = Some (Pending_mod s pt ir) => !ir.`3){1}
        /\ (forall b j, Game4.tested = None => (b, j) \in Game4.s_smap => !get_ir_test (oget Game4.s_smap.[(b,j)])){1}
        /\ (forall i, Game4.tested = None => i \in Game4.c_smap => !get_ir_test (oget Game4.c_smap.[i])){1}
        /\ (forall b1 b2 j1 j2, (b1, j1) \in Game4.s_smap => (b2, j2) \in Game4.s_smap => get_ir_test (oget Game4.s_smap.[(b1, j1)])
             => get_ir_test (oget Game4.s_smap.[(b2, j2)]) => (b1, j1) = (b2, j2)){1}
        /\ (forall i1 i2, i1 \in Game4.c_smap => i2 \in Game4.c_smap => get_ir_test (oget Game4.c_smap.[i1]) 
             => get_ir_test (oget Game4.c_smap.[i2]) => i1 = i2){1}
        /\ (forall b j i, (b, j) \in Game4.s_smap => i \in Game4.c_smap => get_ir_test (oget Game4.c_smap.[i]) => !get_ir_test (oget Game4.s_smap.[(b, j)])){1}
        /\ inv_Game4' Game4.tested{1} Game4.tq{1} Game4.bad3{1} Game4.badq{1} Game4.pk_set{1} Game4.m1_set{1} Game4.m2_set{1} Game4.x_set{1} Game4.y_set{1} Game4.s_smap{1}
                   Game4.hq{1} Game4.c_smap{1} Game4.h1m{1} Game4.h2m{1} Game4.servers{1} Game4.comp_tag{1} ==> if Game5Ltk.test_ltkrev{2} then 
              Game4.test_ltkrev{1} = Game5Ltk.test_ltkrev{2} /\ Game4.tested{1} <> None else ={res} /\ 
             ={b0, hm, h1m, h2m, c_smap, s_smap, servers, tested, b_set, x_set, y_set, pk_set, m1_set, m2_set, bad1, bad2, bad3, tq, 
                           hq, badq, test_ephrev_s, test_ltkrev, comp_tag}(Game4, Game5Ltk)
        /\ Game4.b0{1} /\ !Game5Ltk.test_ltkrev{2}
        /\ (forall i s pt ir, i \in Game4.c_smap => Game4.c_smap.[i] = Some (Pending_mod s pt ir) => !ir.`3){1}
        /\ (forall b j, Game4.tested = None => (b, j) \in Game4.s_smap => !get_ir_test (oget Game4.s_smap.[(b,j)])){1}
        /\ (forall i, Game4.tested = None => i \in Game4.c_smap => !get_ir_test (oget Game4.c_smap.[i])){1}
        /\ (forall b1 b2 j1 j2, (b1, j1) \in Game4.s_smap => (b2, j2) \in Game4.s_smap => get_ir_test (oget Game4.s_smap.[(b1, j1)])
             => get_ir_test (oget Game4.s_smap.[(b2, j2)]) => (b1, j1) = (b2, j2)){1}
        /\ (forall i1 i2, i1 \in Game4.c_smap => i2 \in Game4.c_smap => get_ir_test (oget Game4.c_smap.[i1]) 
             => get_ir_test (oget Game4.c_smap.[i2]) => i1 = i2){1}
        /\ (forall b j i, (b, j) \in Game4.s_smap => i \in Game4.c_smap => get_ir_test (oget Game4.c_smap.[i]) => !get_ir_test (oget Game4.s_smap.[(b, j)])){1}
    ) Game4_inv_s_test' => // [/#|/#|].
  proc; inline.
  sp; if => //.
  sp; if => //.
  match = => //.
  + auto => />.
  move => st.
  match = => //.
  + auto => />.
  + move => s t k ir.
    if => //; 2: by auto => />.
    rcondf {1} ^if. auto => />.
    rcondf {2} ^if. auto => />.
    sp 2 2; if {2} => //.
    + sp; seq 1 1: (#pre /\ ={ks2}); 1: by auto => />.
      if => //.
      + auto => |> &2 *. smt(get_setE mem_set).
      auto => |> &2 *. smt(get_setE mem_set).
    auto => |> &2 *. 
  auto => />.
- move => &2 bad.
  proc; sp; if => //.
  rcondf ^if. auto => />.
  auto => />.
- move => &1.
  proc; inline.
  rcondf ^if; auto => />.
qed.

(* ------------------------------------------------------------------------------------------ *)
(* Removing keys from state *)
local op s_clear_sk (s : server_state) =
match s with
| Honest_mod sk => Honest_mod witness
| Corrupt_mod sk => Corrupt_mod witness
| Dishonest_mod => s
end.

local op clear_opt_c (s : c_state option) : (pkey * skey) option = if s <> None then Some ((oget s).`1, witness) else None.

local op c_clear_esk (s : c_state instance_state) = 
match s with
| Pending_mod st pt ir => let (pk, sk) = st in Pending_mod (pk, witness) pt ir
| Accepted_mod st t k ir => let (pk, sk) = st in Accepted_mod (pk, witness) t k ir
| Aborted_mod st t ir => Aborted_mod (clear_opt_c st) t ir
end.

local op clear_ltsk_opt_s (s : s_state option) : (skey * skey option) option = if s <> None then Some (witness, (oget s).`2) else None.

local op s_clear_ltsk (s : s_state instance_state) = 
match s with 
| Pending_mod st pt ir => let (sk, esk) = st in Pending_mod (witness, esk) pt ir
| Accepted_mod st t k ir => let (sk, esk) = st in Accepted_mod (witness, esk) t k ir
| Aborted_mod st t ir => Aborted_mod (clear_ltsk_opt_s st) t ir
end.

local op clear_esk_opt_s (s : s_state option) : (skey * skey option) option = if s <> None then Some ((oget s).`1, witness) else None.

local op s_clear_esk (s : s_state instance_state) = 
match s with 
| Pending_mod st pt ir => let (ltsk, esk) = st in Pending_mod (ltsk, witness) pt ir
| Accepted_mod st t k ir => let (ltsk, esk) = st in Accepted_mod (ltsk, witness) t k ir
| Aborted_mod st t ir => Aborted_mod (clear_esk_opt_s st) t ir
end.

(* Equivalence of partnering notions after keys are cleared *)
local lemma c_eq_have_p_ce tr sml smr:
  (forall h, omap (fun (v: s_state instance_state) => s_clear_esk v) sml.[h] = smr.[h]) =>
get_partners_c tr sml = get_partners_c tr smr.
proof.
move=> eqsm.
have -> //: get_partners_c tr sml = get_partners_c tr smr.
rewrite /get_origins_c; apply: fsetP=> x; rewrite !mem_fdom.
rewrite !mem_filter !domE -eqsm.
by case: (sml.[x])=> /#.
qed.

local lemma c_eq_have_fresh_p_ce tr sml smr sm2:
  (forall h, omap (fun (v: s_state instance_state) => s_clear_esk v) sml.[h] = smr.[h]) =>
get_fresh_partners_c tr sml sm2 = get_fresh_partners_c tr smr sm2.
proof.
move=> eqsm.
rewrite /get_fresh_partners_c; apply: fsetP=> x; rewrite !mem_fdom.
rewrite !mem_filter !domE -eqsm.
by case: (sml.[x])=> /#.
qed.

local lemma c_eq_partners_ce tr sml smr: 
  (forall h, omap (fun (v: s_state instance_state) => s_clear_esk v) sml.[h] = smr.[h]) =>
untested_partner_c tr sml = untested_partner_c tr smr.
proof.
move=> eqsm @/untested_partner_c.
have ->: get_partners_c tr sml = get_partners_c tr smr.
+ rewrite /get_partners_c; apply: fsetP=> x; rewrite !mem_fdom.
  rewrite !mem_filter !domE -eqsm.
  by case: (sml.[x])=> /#.
have -> //: get_untested_partners_c tr sml = get_untested_partners_c tr smr.
rewrite /get_untested_partners_c; apply: fsetP=> x; rewrite !mem_fdom.
rewrite !mem_filter !domE -eqsm.
by case: (sml.[x])=> /#.
qed.

local lemma c_eq_origins_ce tr sml smr: 
  (forall h, omap (fun (v: s_state instance_state) => s_clear_esk v) sml.[h] = smr.[h]) =>
tested_origins_c tr sml = tested_origins_c tr smr.
proof.
move=> eqsm; rewrite /tested_origins_c.
have ->: get_origins_c tr sml = get_origins_c tr smr.
+ rewrite /get_origins_c; apply: fsetP=> x; rewrite !mem_fdom.
  rewrite !mem_filter !domE -eqsm.
  by case: (sml.[x])=> /#.
have -> //: get_tested_origins_c tr sml = get_tested_origins_c tr smr.
rewrite /get_tested_origins_c; apply: fsetP=> x; rewrite !mem_fdom.
rewrite !mem_filter !domE -eqsm.
by case: (sml.[x])=> /#.
qed.

local lemma c_eq_fresh_ce tr sm1l sm1r sm2: 
  (forall h, omap (fun (v: s_state instance_state) => s_clear_esk v) sm1l.[h] = sm1r.[h]) =>
fresh_partner_c tr sm1l sm2 = fresh_partner_c tr sm1r sm2.
proof.
move=> eqsm; rewrite /fresh_partner_c.
have ->: get_fresh_partners_c tr sm1l sm2 = get_fresh_partners_c tr sm1r sm2.
+ rewrite /get_fresh_partners_c; apply: fsetP=> x; rewrite !mem_fdom.
  rewrite !mem_filter !domE -eqsm.
  by case: (sm1l.[x])=> /#.
have -> //: get_partners_c tr sm1l = get_partners_c tr sm1r.
rewrite /get_origins_c; apply: fsetP=> x; rewrite !mem_fdom.
rewrite !mem_filter !domE -eqsm.
by case: (sm1l.[x])=> /#.
qed.

local lemma c_eq_pot_partner_ce b sml smr cml cmr: 
  (forall h, omap (fun (v: s_state instance_state) => s_clear_esk v) sml.[h] = smr.[h]) =>
  (forall h, omap (fun (v: c_state instance_state) => c_clear_esk v) cml.[h] = cmr.[h]) =>
tested_pot_partner_c b cml sml = tested_pot_partner_c b cmr smr.
proof.
move=> eqsm eqcm; rewrite /tested_pot_partner_c.
have ->: get_tested_pot_partner_c b cml sml = get_tested_pot_partner_c b cmr smr; 2: done.
rewrite /get_tested_pot_partner_c; apply: fsetP=> x; rewrite !mem_fdom.
rewrite !mem_filter !domE -eqcm.
by case: (cml.[x])=> /#.
qed.

local lemma c_eq_have_p_cl tr sml smr:
  (forall h, omap (fun (v: s_state instance_state) => s_clear_ltsk v) sml.[h] = smr.[h]) =>
get_partners_c tr sml = get_partners_c tr smr.
proof.
move=> eqsm.
rewrite /get_partners_c; apply: fsetP=> x; rewrite !mem_fdom.
rewrite !mem_filter !domE -eqsm.
