      , ={b0, servers, c_smap, s_smap, tested, b_set, x_set, y_set, pk_set, m1_set, m2_set, hm, h1m, h2m, bad1, bad2, bad3, nih1m}(Game4, Game5)
      , ={bad3}(Game4, Game5)) => //; try sim />.

