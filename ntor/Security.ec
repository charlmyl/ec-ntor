local lemma c_eq_fresh_cl tr sm1l sm1r sm2l sm2r: 
  (forall h, omap (fun (v: s_state instance_state) => s_clear_ltsk v) sm1l.[h] = sm1r.[h]) =>
  (forall h, omap (fun (v: server_state) => s_clear_sk v) sm2l.[h] = sm2r.[h]) =>
