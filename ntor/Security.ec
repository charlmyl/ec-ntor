                  (exists (m2o : (pkey * tag) option), get_trace val = Some (t'{2}.`1, m2o)) /\ get_ir_test val = false /\
                  get_ir_sess val = false /\ get_ir_eph val = false) Game5Eph.c_smap{2})). 
          + rewrite fsetP.
            move => x.
            do rewrite mem_fdom mem_filter.
            have->: t'{1} = t'{2} by smt().
            by split; move : inv5 inv6; clear; smt().
          smt().
        smt().
      move : G4inv => /> 8? inv4 ? inv7 *.
      move : fresh.
      have->: ! get_ir_eph (oget Red_Eph.Red_O.s_smap{1}.[b{2}, j{2}]) by smt().
      rewrite !negb_or negb_and //= => [#] nses.
      rewrite /fresh_partner_s => fp.
      have : card (get_fresh_partners_s t'{1} Red_Eph.Red_O.c_smap{1}) <> 0 by smt().
      move => ps.
      have : card (get_fresh_partners_s t'{1} Red_Eph.Red_O.c_smap{1}) = 1.
      + move : ps.  
        rewrite fcard_eq0 => /mem_pick /mem_fdom.
        rewrite mem_filter //= => [#] psin [m] H1 H2 H3 H4.
        rewrite fcard_eq1.
        exists (pick (get_fresh_partners_s t'{1} Red_Eph.Red_O.c_smap{1})). 
        apply in_eq_fset1.
        rewrite {1} /get_fresh_partners_s => x0.
        rewrite mem_fdom mem_filter //=.
        split; 2: by smt().
        move => [#] x0in [m2] x0tr x0t x0s x0e.
        have := inv7 x0 (pick (get_fresh_partners_s t'{1} Red_Eph.Red_O.c_smap{1})) t'{1}.`1.`1 t'{1}.`1.`1 t'{1}.`1.`2 m2 m.
        have->: Game5Eph.c_smap{2}.[x0] <> None by smt().
        have->: Game5Eph.c_smap{2}.[(pick (get_fresh_partners_s t'{1} Red_Eph.Red_O.c_smap{1}))] <> None by smt().
        have->: get_trace (oget Game5Eph.c_smap{2}.[x0]) = Some ((t'{1}.`1.`1, t'{1}.`1.`2), m2).
        + move : inv6 x0tr. clear. smt().
        have->: get_trace (oget Game5Eph.c_smap{2}.[(pick (get_fresh_partners_s t'{1} Red_Eph.Red_O.c_smap{1}))]) 
                  = Some ((t'{1}.`1.`1, t'{1}.`1.`2), m).
        + move : inv6 H1. clear. smt().
        smt().
      rewrite fcard_eq1.
      move => [a] aeq.
      have : a \in get_fresh_partners_s t'{1} Red_Eph.Red_O.c_smap{1} by smt(in_fset1).
      rewrite /get_fresh_partners_s mem_fdom mem_filter //=.
      move => [#] H1 [m] H2 H3 H4 H5.
      have : t'{1}.`1.`2 \in Game5Eph.m1_set{2}.
      + have := inv4 a t'{1}.`1 m.
        have->: Game5Eph.c_smap{2}.[a] <> None by smt().
        have->:  get_trace (oget Game5Eph.c_smap{2}.[a]) = get_trace (oget Red_Eph.Red_O.c_smap{1}.[a]).
        + move : inv6. clear. smt().
        smt().
      move => m1in.
      have := inv8 t'{1}.`1.`2.
      rewrite m1in //=.
      move => [i] [#] iin ieq.
      exists i (oget Red_Eph.Red_O.j_inst{1}.[(b{2}, j{2})]).
      do split; smt(loggK expgK expM).
    auto => |> &1 &2 24? inv inv2  *. do split; ~1: smt().
    have->: (get_fresh_partners_s t'{1} Red_Eph.Red_O.c_smap{1}) = (get_fresh_partners_s t'{2} Game5Eph.c_smap{2}).
    + rewrite /get_fresh_partners_s. 
      have->: (fdom (filter (fun (_ : int) (val : pr_st_client instance_state) => (exists (m2o : (pkey * tag) option),
                 get_trace val = Some (t'{1}.`1, m2o)) /\  get_ir_test val = false /\
                get_ir_sess val = false /\ get_ir_eph val = false) Red_Eph.Red_O.c_smap{1})) = (fdom
              (filter (fun (_ : int) (val : pr_st_client instance_state) => (exists (m2o : (pkey * tag) option), get_trace val = Some (t'{2}.`1, m2o)) /\
                get_ir_test val = false /\ get_ir_sess val = false /\ get_ir_eph val = false) Game5Eph.c_smap{2})). 
      + rewrite fsetP.
        move => x.
        do rewrite mem_fdom mem_filter.
        have->: t'{1} = t'{2} by smt().
        by split; move : inv inv2; clear; smt().
      smt().
    smt().
  match Aborted_mod {2} ^match. auto => /#.
  auto => />.
- move => &2 bad; proc; inline. 
  sp; if => //.
  sp; if => //; match => //. 
  match => //.
  if => //; if => //.
  + sp; if => //.
    + auto => />. by rewrite dkey_ll.
    auto => />.
  sp; if => //. 
  + sp 1; seq 1 : (#pre); try by auto => />.
    + auto => />. by rewrite dkey_ll.
    + auto => />. by rewrite dkey_ll.
    hoare. 
    by auto => />.
  auto => />.
- move => &1; proc; inline.
  sp; if => //.
  sp; if => //.
  sp; match => //. 
  match; auto => />.
  if => //; if => //. 
  + sp; if => //. 
    + by auto => />; rewrite dkey_ll.
    auto => //.
  sp; if => //.
  + by auto => />; rewrite dkey_ll.
  auto => //.
qed.


(* One-sided invariant for Game5Ltk *)
op inv_Red_Ltk (tested : int option,
tltkr : bool,
b0 : bool,
b1 : bool,
b2 : bool,
pks : pkey fset,
m1s : pkey fset,
m2s : pkey fset,
xs : pkey fset,
ys : pkey fset,
bs : pkey fset,
ssm : (pkey * int, pr_st_server instance_state) fmap, 
csm : (int, pr_st_client instance_state) fmap,
h1m : (pkey option * pkey option * pkey * pkey * pkey, tag) fmap, 
h2m : (pkey option * pkey option * pkey * pkey * pkey, key) fmap, 
servers : (pkey, server_state) fmap,
ci : int,
cb : int,
ii : (int, int) fmap,
bi : (pkey, int) fmap,
cn : int,
cm : int,
xm : (int, exp) fmap,
ym : (int, exp) fmap,
cr1 : int fset,
cr2 : int fset) = (b0) /\ (tltkr => tested <> None)
         /\ (forall b, b \in servers => b \in bi /\ (oget bi.[b]) \in ym /\ b = g ^ (oget ym.[oget bi.[b]]))
         /\ (forall m, m \in m1s <=> (exists i, i \in xm /\ m = g ^ oget xm.[i]))
         /\ (forall i pk, i \in xm => pk = g ^ oget xm.[i] => pk \in m1s)
         /\ (forall j pk, j \in ym => pk = g ^ oget ym.[j] => pk \in pks) 
         /\ (forall j pk, j \in ym => pk = g ^ oget ym.[j] => !b1 => !b2 => pk \in servers)
         /\ (forall b, b \in servers => (b \in pks /\ (exists j, j \in ym /\ b = g ^ oget ym.[j])))
         /\ (forall b, b \in servers => b \in bi => (oget bi.[b]) \in ym 
                      => b = g ^ (oget ym.[(oget bi.[b])]) 
                      => ((get_sr_ltk (oget servers.[b]) <=> (oget bi.[b]) \in cr2)))

         /\ (forall x, x \in h1m => (x.`3 \in pks \/ x.`3 \in bs) /\ (x.`4 \in m1s \/ x.`4 \in xs) 
                      /\ (x.`5 \in m2s \/ x.`5 \in ys))
         /\ (forall x, x \in h2m => (x.`3 \in pks \/ x.`3 \in bs) /\ (x.`4 \in m1s \/ x.`4 \in xs) 
                      /\ (x.`5 \in m2s \/ x.`5 \in ys))

         /\ (forall n i, cn < n => n \notin xm /\ n \notin cr1 /\ ii.[i] <> Some n)
         /\ (forall m b, cm < m => m \notin ym /\ m \notin cr2 /\ bi.[b] <> Some m)
         /\ (cn = ci)
         /\ (cm = cb)
         /\ (forall i i', i \in ii => i' \in ii => ii.[i] = ii.[i'] => i = i')
         /\ (forall b b', b \in bi => b' \in bi => bi.[b] = bi.[b'] => b = b')

         /\ (forall i t1 t2, csm.[i] <> None => get_trace (oget csm.[i]) = Some (t1, t2) => t1.`2 \in m1s)
         /\ (forall bj t1 t2, ssm.[bj] <> None => get_trace (oget ssm.[bj]) = Some (t1, Some t2) => t2.`1 \in m2s)
         /\ (forall i i' b b' m1 m2 m2', csm.[i] <> None /\ get_trace (oget csm.[i]) = Some ((b, m1), m2)
              => csm.[i'] <> None /\ get_trace (oget csm.[i']) = Some ((b', m1), m2')
              => i = i')
         /\ (forall i i' m1 m2 tag m1' tag', ssm.[i] <> None /\ get_trace (oget ssm.[i]) = Some (m1, Some (m2, tag))
              => ssm.[i'] <> None /\ get_trace (oget ssm.[i']) = Some (m1', Some (m2, tag'))
              => i = i')

         /\ (forall i, i \in csm => get_trace (oget csm.[i]) <> None 
               /\ (oget (get_trace (oget csm.[i]))).`1.`2 \in m1s)
         /\ (forall b j, (b, j) \in ssm => get_trace (oget ssm.[(b, j)]) <> None)
         /\ (forall b j, (b, j) \in ssm => get_ir_test (oget ssm.[(b, j)]) 
               => (exists i, i \in csm /\ (oget (get_trace (oget ssm.[(b, j)]))).`1 = (oget (get_trace (oget csm.[i]))).`1))

         /\ (forall i st pt ir, i \in csm => csm.[i] = Some (Pending_mod st pt ir)
              => pt.`2 \in m1s /\ pt.`1 = st.`1 /\ pt.`1 \in servers /\ !ir.`3 
                      /\ i \in ii /\ (oget ii.[i]) \in xm /\ pt.`2 = g ^ oget xm.[(oget ii.[i])]
                      /\ (ir.`1 <=> (oget ii.[i]) \in cr1) /\ st.`1 \in bi /\ (oget bi.[st.`1]) \in ym)
         /\ (forall i st t k ir, i \in csm => csm.[i] = Some (Accepted_mod st t k ir)
              => t.`1.`2 \in m1s /\ t.`1.`1 = st.`1 /\ st.`1 \in servers 
                      /\ ((oget t.`2).`1 \in m2s \/ (oget t.`2).`1 \in ys)
                      /\ i \in ii /\ (oget ii.[i] \in xm) /\ t.`1.`2 = g ^ oget xm.[(oget ii.[i])]
                      /\ (ir.`1 <=> (oget ii.[i]) \in cr1) /\ st.`1 \in bi /\ (oget bi.[st.`1]) \in ym
                      /\ t.`1.`1 = g ^ (oget ym.[(oget bi.[st.`1])])
                      /\ (oget bi.[st.`1] \in cr2 <=> get_sr_ltk (oget servers.[t.`1.`1])))
         /\ (forall bj st t k ir, bj \in ssm => ssm.[bj] = Some (Accepted_mod st t k ir)
              => t.`1.`1 \in servers /\ t.`1.`1 = bj.`1
                      /\ t.`2 <> None /\ st.`2 <> None /\ g ^ (oget st.`2) = (oget t.`2).`1
                      /\ g ^ (oget st.`2) \in m2s /\ g ^ (oget st.`2) \notin servers
                      /\ (t.`1.`2 \in m1s \/ t.`1.`2 \in xs)
                      /\ bj.`1 \in bi /\ (oget bi.[bj.`1]) \in ym /\ t.`1.`1 = g ^ (oget ym.[(oget bi.[bj.`1])]))

         /\ (forall b j, tested = None => (b, j) \in ssm => !get_ir_test (oget ssm.[(b,j)]))
         /\ (forall i, tested = None => i \in csm => !get_ir_test (oget csm.[i]))

         /\ (forall i int m1 m2, i \in csm => get_trace (oget csm.[i]) = Some (m1, m2) => int \in xm
              => m1.`2 = g ^ (oget xm.[int]) => int \in cr1 => get_ir_eph (oget csm.[i])).

