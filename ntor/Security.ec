              => (exists j, (j \in O_CDH.y_map{1}) /\ x.`3 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`2 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => (Some x.`1, None, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, None, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2} 
              => (x.`3 \in R_Ltk.Red_O.servers{1})
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`2 = x.`3 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists j, (j \in O_CDH.y_map{1}) /\ x.`3 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`2 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2} 
              => (x.`3 \in R_Ltk.Red_O.servers{1})
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`2 = x.`3 ^ oget O_CDH.x_map{1}.[i])
              => (exists j, j \in O_CDH.y_map{1} /\ x.`5 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`1 = x.`4 ^ oget O_CDH.y_map{1}.[j])
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2} 
              => (x.`3 \in R_Ltk.Red_O.servers{1}) => x.`4 \in R_Ltk.Red_O.m1_set{1}
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists j, (j \in O_CDH.y_map{1}) /\ x.`5 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`1 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2} 
              => (x.`3 \in R_Ltk.Red_O.servers{1}) => ! ((x{2}.`4 \notin Game5Ltk.m1_set{2}) /\ (x{2}.`5 \in Game5Ltk.m2_set{2}) /\ (x{2}.`5 \notin R_Ltk.Red_O.servers{1}))
              => (exists j, (j \in O_CDH.y_map{1}) /\ x.`3 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`2 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists j, (j \in O_CDH.y_map{1}) /\ x.`5 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`1 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2} 
              => x.`3 \notin R_Ltk.Red_O.servers{1}
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h2m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2} 
