- proc; inline. 
  rcondt{2} ^if. auto => />.
  sp; match = => // sk.
  match = => //.
  + seq 1 1: (#pre /\ ={sk}); 1: by auto.
  sp 0 4; if{2}.
  + rcondt{2} ^if. auto => />.
    by auto => />. 
  auto.
- move => &2 bad.
  proc; inline; sp; match; auto => />.
  match; auto => />.
  rewrite dt_ll weight_dprod dkey_ll dtag_ll. 
  smt().
- move => &1. 
  proc; inline.
  rcondf ^if; auto => />.

- proc; inline.
