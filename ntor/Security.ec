        have := inv11 b{2}.
        have<-: get_sr_ltk (oget Game5Ltk.servers{2}.[b{2}]) = get_sr_ltk (oget R_Ltk.Red_O.servers{1}.[b{2}]).
        + move : inv4. clear. smt().
        smt().
      move => *. do split; ~1,3,6,7,9,10: smt(get_setE mem_set in_fsetU1 loggK expgK expM).
      + have->: (get_fresh_partners_s t'{1} R_Ltk.Red_O.c_smap{1}) = (get_fresh_partners_s t'{2} Game5Ltk.c_smap{2}). 
        + have->: t'{1} = t'{2} by smt().
          by move : inv4 inv7 inv14; clear; smt(s_eq_have_fresh_p_ce).
        by split; move : inv4 inv7 inv14; clear; smt().
      + move : inv4 nltk. clear. smt().
      + move : G5inv => /> 3? inv8 4? inv11 6? inv9 ? inv2 inv3 5? inv10 2? inv13 inv15.
        move : fresh.
        rewrite !negb_or negb_and nltk //= => [#] nses.
        rewrite /fresh_partner_s => fp.
        have : card (get_fresh_partners_s t'{1} R_Ltk.Red_O.c_smap{1}) <> 0 by smt().
        move => ps.
        have : card (get_fresh_partners_s t'{1} R_Ltk.Red_O.c_smap{1}) = 1.
        + move : ps.  
          rewrite fcard_eq0 => /mem_pick /mem_fdom.
          rewrite mem_filter //= => [#] psin [m] H1 H2 H3 H4.
          rewrite fcard_eq1.
          exists (pick (get_fresh_partners_s t'{1} R_Ltk.Red_O.c_smap{1})). 
          apply in_eq_fset1.
          rewrite {1} /get_fresh_partners_s => x0.
          rewrite mem_fdom mem_filter //=.
          split; 2: smt().
          move => [#] x0in [m2] x0tr x0t x0s x0e.
          have := inv2 x0 (pick (get_fresh_partners_s t'{1} R_Ltk.Red_O.c_smap{1})) t'{1}.`1.`1 t'{1}.`1.`1 t'{1}.`1.`2 m2 m.
          have->: R_Ltk.Red_O.c_smap{1}.[x0] <> None by smt().
          have->: R_Ltk.Red_O.c_smap{1}.[(pick (get_fresh_partners_s t'{1} R_Ltk.Red_O.c_smap{1}))] <> None by smt().
          have->: get_trace (oget R_Ltk.Red_O.c_smap{1}.[x0]) = Some ((t'{1}.`1.`1, t'{1}.`1.`2), m2).
          + move : inv7 x0tr. clear. smt().
          have->: get_trace (oget R_Ltk.Red_O.c_smap{1}.[(pick (get_fresh_partners_s t'{1} R_Ltk.Red_O.c_smap{1}))]) 
                    = Some ((t'{1}.`1.`1, t'{1}.`1.`2), m).
          + move : inv7 H1. clear. smt().
          smt().
        rewrite fcard_eq1.
        move => [a] aeq.
        have : a \in get_fresh_partners_s t'{1} R_Ltk.Red_O.c_smap{1} by smt(in_fset1).
        rewrite /get_fresh_partners_s mem_fdom mem_filter //=.
        move => [#] H1 [m] H2 H3 H4 H5.
        have : t'{1}.`1.`2 \in Game5Ltk.m1_set{2}.
        + have := inv9 a t'{1}.`1 m.
          have->: R_Ltk.Red_O.c_smap{1}.[a] <> None by smt().
          have<-: get_trace (oget Game5Ltk.c_smap{2}.[a]) = get_trace (oget R_Ltk.Red_O.c_smap{1}.[a]).
          + move : inv7. clear. smt().
          smt().
        move => m1in.
        have := inv8 t'{1}.`1.`2.
        rewrite m1in //=.
        move => [int] [#] intin ieq int'.
        do split; ~3,4: smt(get_setE mem_set in_fsetU1 loggK expgK expM).
        + move => i'in x4eq'.
          case (int' \in O_CDH.cr1{1}) => incr1; 2: done.
          have := inv15 int' i'in incr1.
          move => [i0 [#] i0in tri0 i0eph].
          have := inv2 i0 a (oget (get_trace (oget R_Ltk.Red_O.c_smap{1}.[i0]))).`1.`1 t'{1}.`1.`1 t'{1}.`1.`2 (oget (get_trace (oget R_Ltk.Red_O.c_smap{1}.[i0]))).`2 m.
          smt(loggK expgK expM pow_bij some_oget).
        exists int (oget R_Ltk.Red_O.b_inst{1}.[b{2}]).
        do split; ~8: smt(get_setE mem_set pow_bij loggK expgK expM ComRing.mulrC).
        have := inv11 b{2}. 
        have->: b{2} \in R_Ltk.Red_O.servers{1} by smt().
        have->: b{2} \in R_Ltk.Red_O.b_inst{1} by smt().
        have->: oget R_Ltk.Red_O.b_inst{1}.[b{2}] \in O_CDH.y_map{1} by smt().
        have<-: b{2} = g ^ oget O_CDH.y_map{1}.[oget R_Ltk.Red_O.b_inst{1}.[b{2}]] by smt().
        smt().
      + move => i0 s0 t0 k0 ir0 iin iacc.
        do split; 1..4: smt(get_setE loggK expgK expM).
        rewrite !negb_and //=.
        case (ir0.`1) => neph; 1: done.
        case (ir0.`4) => ncor; 1: done.
        have := inv16 i0 s0 t0 k0 ir0 iin iacc => [#] _ _ _ _.
        rewrite neph ncor //=.
        case (exists (bj : pkey * int), (bj \in Game5Ltk.s_smap{2}) /\ get_trace (oget Game5Ltk.s_smap{2}.[bj]) = Some t0); 2: done.
        move => [bj0 H1] _.
        exists bj0.
        smt(mem_set get_setE).
      + move => x0 y0 b0 x1eq x2eq x3eq x4eq x5eq.
        right.
        rewrite -x3eq -x4eq -x5eq.
        have->: b0 = st'{2}.`1 by smt(pow_bij).
        have->: y0 = oget st'{2}.`2 by smt(pow_bij).
        exists (b, j){2} (oget t'{2}.`2).`2 k'{2} (ir'{2}.`1, ir'{2}.`2, true, ir'{2}.`4).
        rewrite mem_set get_setE //=.
        move : G5inv => /> 3? inv8 4? inv11 6? inv9 ? inv2 inv3 5? inv10 2? inv13 inv15 *.
        split. smt().
        have->: g ^ st'{2}.`1 = t'{2}.`1.`1 by smt().
        have->: g ^ oget st'{2}.`2 = (oget t'{2}.`2).`1 by smt().
        smt(get_setE mem_set).
      move => x0 y0 b0 xin.
      have := inv17 x0 y0 b0 xin b3.
      move => [|[[i0 tag H1]|]]; 1,3: smt(get_setE loggK expgK expM).
      right; left.
      exists i0 tag.
      smt(get_setE).
    auto => /> &1 &2 27? inv inv2 43? ltk *. split; 2: smt().
    have->: (get_fresh_partners_s t'{1} R_Ltk.Red_O.c_smap{1}) = (get_fresh_partners_s t'{2} Game5Ltk.c_smap{2}). 
    + have->: t'{1} = t'{2} by smt().
      by move : inv inv2; clear; smt(s_eq_have_fresh_p_ce).
    by split; move : inv inv2; clear; smt().
  match Aborted_mod {2} ^match. auto => /#.
  auto => />.
- move => &2 bad; proc; inline.
  sp; if => //.
  sp; if => //; match => //. 
  match => //.
  if => //; if => //.
  + sp; if => //.
    + auto => />. by rewrite dkey_ll.
    auto => />.
  sp; if => //. 
  + sp 1; seq 1 : (#pre); try by auto => />.
    + auto => />. by rewrite dkey_ll.
    + auto => />. by rewrite dkey_ll.
    hoare. 
    by auto => />.
  auto => />.
- move => &1; proc; inline.
  sp; if => //.
  sp; if => //.
  sp; match => //. 
  match; auto => />.
  if => //; if => //. 
  + sp; if => //.
    + sp; seq 1 : (#pre); try by auto.
      + by auto => />; rewrite dkey_ll.
      + auto => /#.
      hoare.
      by auto => />.
    auto => //.
  sp; if => //.
  + sp; seq 1 : (#pre); try by auto.
    + by auto => />; rewrite dkey_ll.
    + auto => /> &hr *. 
      by rewrite dkey_ll => /#.
    hoare.
    by auto => />.
  auto => //.
qed.



lemma security &m: `| Pr[E_UAKE(O_RPK(S, C, RO), A).run(false) @ &m : res] - Pr[E_UAKE(O_RPK(S, C, RO), A).run(true) @ &m : res]|
  <= Pr[E_CDH(O_CDH, R_Eph(A)).run() @ &m : O_CDH.win] + Pr[E_CDH(O_CDH, R_Ltk(A)).run() @ &m : O_CDH.win]
       + 2%r * q_m2%r * p_max dtag
       + 2%r * ((q_h + q_gen + q_exec + q_m1) * (q_h + q_gen + q_exec + q_m1 - 1))%r / (2 * order)%r 
       + 2%r * ((q_gen + q_exec + q_m1) * (q_gen + q_exec + q_m1 - 1))%r / (2 * order)%r.
proof. 
rewrite !(gake_game0 _).
apply (ler_trans (`|Pr[E_UAKE(Game1, A).run(false) @ &m : res] - Pr[E_UAKE(Game1, A).run(true) @ &m : res]| 
        + 2%r * ((q_gen + q_exec + q_m1) * (q_gen + q_exec + q_m1 - 1))%r / (2 * order)%r)).
+ smt(game0_game1 game0_bad1).
rewrite ler_add2r.
apply (ler_trans (`|Pr[E_UAKE(Game2, A).run(false) @ &m : res] - Pr[E_UAKE(Game2, A).run(true) @ &m : res]| 
        + 2%r * ((q_h + q_gen + q_exec + q_m1) * (q_h + q_gen + q_exec + q_m1 - 1))%r / (2 * order)%r)).
+ smt(game1_game2 game1_bad2).
rewrite ler_add2r.
rewrite !(game2_game2_5 _).
rewrite !game2_5_RO !LRO_game3.
apply (ler_trans (`|Pr[E_UAKE(Game4, A).run(false) @ &m : res] - Pr[E_UAKE(Game4, A).run(true) @ &m : res]| 
        + 2%r * q_m2%r * p_max dtag)).
+ smt(game3_game4 game3_bad3).
rewrite ler_add2r.
apply (ler_trans Pr[E_UAKE(Game4, A).run(true) @ &m : Game4.badq]).
+ rewrite distrC.
  by apply interestingbit.
rewrite split_pr.
apply (ler_trans (Pr[E_UAKE(Game5Eph, A).run(true) @ &m : Game5Eph.badq] + Pr[E_UAKE(Game4, A).run(true) @ &m : Game4.badq /\ Game4.test_ltkrev = false])).
+ rewrite ler_add2r.
  apply game4_game5_eph.
apply (ler_trans (Pr[E_CDH(O_CDH, R_Eph(A)).run() @ &m : O_CDH.win] + Pr[E_UAKE(Game4, A).run(true) @ &m : Game4.badq /\ Game4.test_ltkrev = false])).
+ rewrite ler_add2r.
  apply cdh_red_eph.
apply (ler_trans (Pr[E_CDH(O_CDH, R_Eph(A)).run() @ &m : O_CDH.win] + Pr[E_UAKE(Game5Ltk, A).run(true) @ &m : Game5Ltk.badq])).
+ rewrite ler_add2l.
  apply game4_game5_ltk.
rewrite ler_add2l.
apply cdh_red_ltk.
qed.


end section.




