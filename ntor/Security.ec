  do split; ~1,4,8,9,10: smt(get_setE in_fsetU1 in_fsetU pow_bij mem_set).
  + move => x0 y0 b0 tqeq.
    have := inv x0 y0 b0 tqeq.
    move => [H1] [H2|H3]. 
    + split; 1: smt(mem_set).
      left.
      move : H2 => [i'] t k ir'' H2.
