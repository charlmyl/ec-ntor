          have pteq : (oget (get_trace (oget Game5Eph.s_smap{2}.[i2.`1, i2.`2]))).`1 = (x.`3, x.`4) by smt().
          have->: t{2}.`1.`2 = x.`4 by smt().
          rewrite -pteq i3tr.
          have->: Game5Eph.c_smap{2}.[i3] <> None by smt(). 
          have->: get_trace (oget Game5Eph.c_smap{2}.[i3]) = Some ((oget (get_trace (oget Game5Eph.c_smap{2}.[i3]))).`1,
          (oget (get_trace (oget Game5Eph.c_smap{2}.[i3]))).`2).
