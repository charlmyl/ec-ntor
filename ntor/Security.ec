  sp; if => //.  
  + auto => /> &1 &2 *. smt(mem_set get_setE). 

- sim />.

- proc; inline.
  sp; if => //.
  sp; if => //.
  sp; match.
  + smt().
  + smt().
  + by auto=> />; smt(get_setE).
  move=> stl str; auto=> />.

- proc; inline.
