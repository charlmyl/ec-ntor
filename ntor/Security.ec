        move => [|[[i0 tag H1]|]]; 1,3: smt(get_setE loggK expgK expM).
        right; left.
        exists i0 tag.
        smt(get_setE).
      auto => |> &1 &2 28? inv4 inv14 inv7 ? inv12 ? inv16 3? inv ? inv17 G5inv b1 b2 b3 2? fresh nltk *. 
      split.
      + move => []; 1: smt().
        move : G5inv => /> 3? inv8 4? inv11 6? inv9 ? inv2 inv3 5? inv10 2? inv13 inv15 inhq.
        case (O_CDH.win{1}) => nwin; 1: done.
        have := inv10 (b, j){2} st'{1} t'{1} k'{1} ir'{1}.
        have->: ((b{2}, j{2}) \in R_Ltk.Red_O.s_smap{1}) by smt().
        have->: R_Ltk.Red_O.s_smap{1}.[(b{2}, j{2})] = Some (Accepted_mod st'{1} t'{1} k'{1} ir'{1}) by smt().
        move => [#] st1eq ins beq trnn stnn *.
        have : t'{1}.`1.`2 \in Game5Ltk.m1_set{2}.
        + move : fresh.
          rewrite !negb_or negb_and nltk //= => [#] nses.
          rewrite /fresh_partner_s => fp.
          have : card (get_fresh_partners_s t'{1} R_Ltk.Red_O.c_smap{1}) <> 0 by smt().
          rewrite /get_fresh_partners_s fcard_eq0 => /mem_pick /mem_fdom.
          rewrite mem_filter /=.
          move => [H1 [#] [m] H2 H3 H4 H5].
          have := inv9 (pick (fdom (filter (fun (_ : int) (val : c_state instance_state) => (exists (m2o : (pkey * tag) option),
                  get_trace val = Some (t'{1}.`1, m2o)) /\ get_ir_test val = false /\
               get_ir_sess val = false /\ get_ir_eph val = false) R_Ltk.Red_O.c_smap{1}))) t'{1}.`1 m.
          have->: R_Ltk.Red_O.c_smap{1}.[pick (fdom (filter (fun (_ : int) (val : c_state instance_state) 
                    => (exists (m2o : (pkey * tag) option), get_trace val = Some (t'{1}.`1, m2o)) /\
                       get_ir_test val = false /\ get_ir_sess val = false /\ get_ir_eph val = false) R_Ltk.Red_O.c_smap{1}))] <> None by smt().
          have<-: get_trace (oget Game5Ltk.c_smap{2}.[pick (fdom (filter (fun (_ : int)
                    (val : c_state instance_state) => (exists (m2o : (pkey * tag) option), get_trace val = Some (t'{1}.`1, m2o)) /\
                  get_ir_test val = false /\ get_ir_sess val = false /\ get_ir_eph val = false) R_Ltk.Red_O.c_smap{1}))]) = get_trace
                    (oget R_Ltk.Red_O.c_smap{1}.[pick (fdom (filter (fun (_ : int) (val : c_state instance_state) 
                    => (exists (m2o : (pkey * tag) option), get_trace val = Some (t'{1}.`1, m2o)) /\ get_ir_test val = false /\
                       get_ir_sess val = false /\ get_ir_eph val = false) R_Ltk.Red_O.c_smap{1}))]).
          + move : inv7. clear. smt().
          smt().
        move => m1in.
        have : (exists (i : int), (i \in O_CDH.x_map{1}) /\ t'{1}.`1.`2 = g ^ oget O_CDH.x_map{1}.[i]) by smt().
        move => [i] [#] iin ieq.
        have x3ins: (t'{2}.`1.`2 ^ oget st'{2}.`2, t'{2}.`1.`2 ^ st'{2}.`1, g ^ st'{2}.`1, t'{2}.`1.`2, g ^ oget st'{2}.`2).`3 \in
                      R_Ltk.Red_O.servers{1} by smt().
        have := inv12 (t'{2}.`1.`2 ^ oget st'{2}.`2, t'{2}.`1.`2 ^ st'{2}.`1, g ^ st'{2}.`1, t'{2}.`1.`2, g ^ oget st'{2}.`2) 
                  i (oget R_Ltk.Red_O.b_inst{1}.[b{2}]) inhq b1 b2 b3 nwin x3ins.
        simplify.
        rewrite !negb_or //=.
        do split; ~4,7: smt(loggK expgK expM).
        + move : fresh.
          rewrite !negb_or negb_and nltk //= => [#] nses.
          rewrite /fresh_partner_s => fp.
          have : card (get_fresh_partners_s t'{1} R_Ltk.Red_O.c_smap{1}) <> 0 by smt().
          rewrite /get_fresh_partners_s fcard_eq0 => /mem_pick /mem_fdom.
          rewrite mem_filter /=.
