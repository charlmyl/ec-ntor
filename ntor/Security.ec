    smt(s_eq_fresh_ck).
  if => //.
  + auto => />.
    smt(get_setE).
  auto => />.
  smt(get_setE).

by auto => />; smt(map_empty emptyE). *)
qed.


lemma LRO_game4 bit &m: Pr[ROSc.I2.MainD(Red_ROM2(A, ROSc.I1.RO), ROSc.I2.LRO).distinguish(bit) @ &m : res] = Pr[E_GAKE_nodhs(Game4, A).run(bit) @ &m : res].
