        case (x0 \in R_Ltk.Red_O.c_smap{1}) => xin; 2: smt().
        case (get_trace (oget R_Ltk.Red_O.c_smap{1}.[x0]) = Some (oget (get_trace (oget R_Ltk.Red_O.s_smap{1}.[bj.`1, bj.`2])))); 2: smt().
