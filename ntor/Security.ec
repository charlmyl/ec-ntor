lemma game4_game5_ltk &m: Pr[E_UAKE(Game4, A).run(true) @ &m : Game4.badq /\ Game4.test_ltkrev = false] <= 
                  Pr[E_UAKE(Game5Ltk, A).run(true) @ &m : Game5Ltk.badq].
proof.
byequiv (: ={glob A, arg} /\ arg{1} = true ==> _) => //.
proc; inline.
