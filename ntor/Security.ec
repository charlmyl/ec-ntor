local lemma s_eq_have_fresh_p_ce tr sml smr:
  (forall h, omap (fun (v: c_state instance_state) => c_clear_esk v) sml.[h] = smr.[h]) =>
get_fresh_partners_s tr sml = get_fresh_partners_s tr smr.
proof.
