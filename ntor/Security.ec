        have:= (inv3 x0 i0 t'.`1 t'.`2 (Some ((oget t'.`2).`1, t))).
        smt(get_setE).
      smt(fcard1 fcards0).
    smt().
  have : (get_ir_test (oget Game4.s_smap{2}.[b{2}, j{2}])).
  + have := inv5 (b,j){2} i0 t'.`1 (oget t'.`2).`1 (oget t'.`2).`2 t'.`1 t.
    move => H4.
    have->: (b,j){2} = i0 by smt(get_setE mem_set).
