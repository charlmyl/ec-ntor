    auto => /> &1 &2 stc stc' 23? inv9 inv8 inv ? inv4' inv5' 3? inv2 ? inv10 17? inv3 3? inv7 inv4 inv5 7? b3 2? fresh *. 
    do split; ~1,3,7,8: smt(get_setE mem_set in_fsetU1 loggK expgK expM).
