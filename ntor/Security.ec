        have->: (card (get_untested_partners_s (oget (get_trace (oget R_Ltk.Red_O.s_smap{1}.[bj.`1, bj.`2]))) R_Ltk.Red_O.c_smap{1}) = 0); 2: by done.
        rewrite fcard_eq0 in_eq_fset0 //=.
        move => x0.
