         /\ (forall xy b x y, (Some xy, None, b, x, y) \in R_Ltk.Red_O.h2m_opt{1} => (xy, x ^ (loge b), b, x, y) \in Game5Ltk.h2m{2})
         /\ (forall (x : group * group * group * group * group), (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h2m_opt{1} => x \in Game5Ltk.h2m{2})

         /\ (Game5Ltk.tq{2} <> None => oget Game5Ltk.tq{2} \in Game5Ltk.hq{2} => O_CDH.win{1})

         /\ (forall pk, omap s_clear_sk Game5Ltk.servers{2}.[pk] = R_Ltk.Red_O.servers{1}.[pk])
         /\ (forall bj, omap s_clear_ltsk Game5Ltk.s_smap{2}.[bj] = R_Ltk.Red_O.s_smap{1}.[bj])
         /\ (forall i, omap c_clear_esk Game5Ltk.c_smap{2}.[i] = R_Ltk.Red_O.c_smap{1}.[i])

         (* more relational stuff for tq and hq *)
         /\ (forall x i, Game5Ltk.tq{2} = Some x => (x.`3 \in R_Ltk.Red_O.servers{1})
                     /\ x \in Game5Ltk.h2m{2}
                     /\ (i \in O_CDH.x_map{1} => x.`4 = g ^ oget O_CDH.x_map{1}.[i] => i \notin O_CDH.cr1{1})
                     /\ (exists (i j : int), (i \in O_CDH.x_map{1}) /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] 
                               /\ x.`1 = x{2}.`5 ^ oget O_CDH.x_map{1}.[i] /\ x.`2 = x{2}.`3 ^ oget O_CDH.x_map{1}.[i]
                               /\ j \in O_CDH.y_map{1} /\ x.`3 = g ^ oget O_CDH.y_map{1}.[j] /\ (i \notin O_CDH.cr1{1}) 
                               /\ (j \notin O_CDH.cr2{1})))
         /\ (forall x i j, x \in Game5Ltk.hq{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2} => !O_CDH.win{1} => x.`3 \in R_Ltk.Red_O.servers{1}
              => i \notin O_CDH.x_map{1} \/ x.`4 <> g ^ (oget O_CDH.x_map{1}.[i]) \/ x.`2 <> x.`3 ^ (oget O_CDH.x_map{1}.[i]) 
                  \/ i \in O_CDH.cr1{1}  \/ j \notin O_CDH.y_map{1} \/ x.`3 <> g ^ (oget O_CDH.y_map{1}.[j]) \/ j \in O_CDH.cr2{1})

         (* one-sided part on the Game5Ltk side *)
         /\ (forall i st pt ir, i \in Game5Ltk.c_smap{2} => Game5Ltk.c_smap{2}.[i] = Some (Pending_mod st pt ir)
              => pt.`2 = g ^ st.`2)
         /\ (forall i st t k ir, i \in Game5Ltk.c_smap{2} => Game5Ltk.c_smap{2}.[i] = Some (Accepted_mod st t k ir)
              => t.`1.`2 = g ^ st.`2
                      /\ t.`2 <> None /\ ((oget t.`2).`1 ^ st.`2, st.`1 ^ st.`2, st.`1, g ^ st.`2, (oget t.`2).`1) \in Game5Ltk.h1m{2}
                      /\ (oget t.`2).`2 = oget Game5Ltk.h1m{2}.[((oget t.`2).`1 ^ st.`2, st.`1 ^ st.`2, st.`1, g ^ st.`2, (oget t.`2).`1)]
                      /\ (!ir.`1 /\ !ir.`4 /\ !(exists bj, bj \in Game5Ltk.s_smap{2} /\ get_trace (oget Game5Ltk.s_smap{2}.[bj]) = Some t) => Game5Ltk.comp_tag{2}))
         /\ (forall bj st t k ir, bj \in Game5Ltk.s_smap{2} => Game5Ltk.s_smap{2}.[bj] = Some (Accepted_mod st t k ir)
              => t.`1.`1 = g ^ st.`1
                      /\ ((t.`1).`2 ^ (oget st.`2), (t.`1).`2 ^ st.`1, g ^ st.`1, (t.`1).`2, g ^ (oget st.`2)) \in Game5Ltk.h1m{2}
                      /\ (oget t.`2).`2 = oget Game5Ltk.h1m{2}.[((t.`1).`2 ^ (oget st.`2), (t.`1).`2 ^ st.`1, g ^ st.`1, (t.`1).`2, g ^ (oget st.`2))])
         /\ (forall b sk, b \in Game5Ltk.servers => obind get_skey Game5Ltk.servers.[b] = Some sk
              => b = g ^ sk){2}
         /\ (forall x, x \in Game5Ltk.h2m{2} => x \in Game5Ltk.h1m{2})
         /\ (forall x y b, Game5Ltk.tq = Some (g ^ (ZModE.( * ) x y), g ^ (ZModE.( * ) x b), g ^ b, g ^ x, g ^ y) 
              => ((exists i tag key ir, i \in Game5Ltk.c_smap /\ Game5Ltk.c_smap.[i] 
                     = Some (Accepted_mod (g ^ b, x) ((g ^ b, g ^ x), Some (g ^ y, tag)) key ir)
                     /\ get_ir_test (oget Game5Ltk.c_smap.[i]))
                  \/ (exists i tag key ir, i \in Game5Ltk.s_smap /\ Game5Ltk.s_smap.[i] 
                       = Some (Accepted_mod (b, Some y) ((g ^ b, g ^ x), Some (g ^ y, tag)) key ir)
                     /\ get_ir_test (oget Game5Ltk.s_smap.[i])))){2}
         /\ (forall x, x \in Game5Ltk.hq => (x.`3 \in Game5Ltk.pk_set \/ x.`3 \in Game5Ltk.b_set) 
              /\ (x.`4 \in Game5Ltk.m1_set \/ (x.`4 \in Game5Ltk.x_set)) /\ (x.`5 \in Game5Ltk.y_set \/ x.`5 \in Game5Ltk.m2_set)){2}
         /\ (forall x y b, (g ^ (ZModE.( * ) x y), g ^ (ZModE.( * ) x b), g ^ b, g ^ x, g ^ y) \in Game5Ltk.h1m{2} => !Game5Ltk.bad3{2}
                => (exists i tag, i \in Game5Ltk.c_smap{2} /\ get_trace (oget Game5Ltk.c_smap{2}.[i]) = Some ((g ^ b, g ^ x), Some (g ^ y, tag)))
                  \/ (exists i tag, i \in Game5Ltk.s_smap{2} /\ get_trace (oget Game5Ltk.s_smap{2}.[i]) = Some ((g ^ b, g ^ x), Some (g ^ y, tag))
                       /\ tag = oget Game5Ltk.h1m{2}.[(g ^ (ZModE.( * ) x y), g ^ (ZModE.( * ) x b), g ^ b, g ^ x, g ^ y)])
                  \/ (g ^ (ZModE.( * ) x y), g ^ (ZModE.( * ) x b), g ^ b, g ^ x, g ^ y) \in Game5Ltk.hq{2})

         (* one-sided part on the RedLtk side *)
         /\ (inv_R_Ltk R_Ltk.Red_O.tested R_Ltk.Red_O.test_ltkrev R_Ltk.Red_O.b0 R_Ltk.Red_O.bad1 R_Ltk.Red_O.bad2
               R_Ltk.Red_O.pk_set R_Ltk.Red_O.m1_set R_Ltk.Red_O.m2_set R_Ltk.Red_O.x_set R_Ltk.Red_O.y_set R_Ltk.Red_O.b_set
               R_Ltk.Red_O.s_smap R_Ltk.Red_O.c_smap R_Ltk.Red_O.h1m_opt R_Ltk.Red_O.h2m_opt R_Ltk.Red_O.servers 
               R_Ltk.Red_O.count_i R_Ltk.Red_O.count_b R_Ltk.Red_O.i_inst R_Ltk.Red_O.b_inst O_CDH.n O_CDH.m
               O_CDH.x_map O_CDH.y_map O_CDH.cr1 O_CDH.cr2){1}

==> if Game5Ltk.badq{2} \/ Game5Ltk.comp_tag{2} then O_CDH.win{1} else ={res}
         /\ ={b0, hm, tested, b_set, x_set, y_set, pk_set, m1_set, m2_set, bad1, bad2, bad3, test_ephrev_s, test_ltkrev, comp_tag}(R_Ltk.Red_O, Game5Ltk)
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => (x.`3 \in R_Ltk.Red_O.servers{1}) => x.`4 \in R_Ltk.Red_O.m1_set{1}
              => (exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] 
                        /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i] /\ x{2}.`2 = x.`3 ^ oget O_CDH.x_map{1}.[i])
              => (None, None, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(None, None, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => (x.`3 \in R_Ltk.Red_O.servers{1}) => x.`5 \in R_Ltk.Red_O.m2_set{1} => x.`5 \notin R_Ltk.Red_O.servers{1} => x.`4 \notin R_Ltk.Red_O.m1_set{1}
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists j, (j \in O_CDH.y_map{1}) /\ x.`5 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`1 = x.`4 ^ oget O_CDH.y_map{1}.[j])
              => (exists j, (j \in O_CDH.y_map{1}) /\ x.`3 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`2 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => (Some x.`1, None, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, None, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => (x.`3 \in R_Ltk.Red_O.servers{1})
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`2 = x.`3 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists j, (j \in O_CDH.y_map{1}) /\ x.`3 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`2 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => (x.`3 \in R_Ltk.Red_O.servers{1})
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`2 = x.`3 ^ oget O_CDH.x_map{1}.[i])
              => (exists j, j \in O_CDH.y_map{1} /\ x.`5 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`1 = x.`4 ^ oget O_CDH.y_map{1}.[j])
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => (x.`3 \in R_Ltk.Red_O.servers{1}) => x.`4 \in R_Ltk.Red_O.m1_set{1}
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists j, (j \in O_CDH.y_map{1}) /\ x.`5 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`1 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => (x.`3 \in R_Ltk.Red_O.servers{1}) => ! ((x{2}.`4 \notin Game5Ltk.m1_set{2}) /\ (x{2}.`5 \in Game5Ltk.m2_set{2}) /\ (x{2}.`5 \notin R_Ltk.Red_O.servers{1}))
              => (exists j, (j \in O_CDH.y_map{1}) /\ x.`3 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`2 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists j, (j \in O_CDH.y_map{1}) /\ x.`5 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`1 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h1m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => x.`3 \notin R_Ltk.Red_O.servers{1}
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} /\ Game5Ltk.h1m{2}.[x] = R_Ltk.Red_O.h1m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h2m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => x.`3 \in R_Ltk.Red_O.servers{1} => x.`4 \in R_Ltk.Red_O.m1_set{1}
              => (exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] 
                        /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i] /\ x{2}.`2 = x.`3 ^ oget O_CDH.x_map{1}.[i])
              => (None, None, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h2m_opt{1} /\ Game5Ltk.h2m{2}.[x] = R_Ltk.Red_O.h2m_opt{1}.[(None, None, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h2m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => (x.`3 \in R_Ltk.Red_O.servers{1}) => x.`5 \in R_Ltk.Red_O.m2_set{1} => x.`5 \notin R_Ltk.Red_O.servers{1} => x.`4 \notin R_Ltk.Red_O.m1_set{1}
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i])
              => !(exists j, (j \in O_CDH.y_map{1}) /\ x.`5 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`1 = x.`4 ^ oget O_CDH.y_map{1}.[j])
              => (exists j, (j \in O_CDH.y_map{1}) /\ x.`3 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`2 = x.`4 ^ oget O_CDH.y_map{1}.[j])
              => (Some x.`1, None, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h2m_opt{1} /\ Game5Ltk.h2m{2}.[x] = R_Ltk.Red_O.h2m_opt{1}.[(Some x.`1, None, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h2m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => (x.`3 \in R_Ltk.Red_O.servers{1})
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`2 = x.`3 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists j, (j \in O_CDH.y_map{1}) /\ x.`3 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`2 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h2m_opt{1} /\ Game5Ltk.h2m{2}.[x] = R_Ltk.Red_O.h2m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h2m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => (x.`3 \in R_Ltk.Red_O.servers{1})
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`2 = x.`3 ^ oget O_CDH.x_map{1}.[i])
              => (exists j, j \in O_CDH.y_map{1} /\ x.`5 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`1 = x.`4 ^ oget O_CDH.y_map{1}.[j])
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h2m_opt{1} /\ Game5Ltk.h2m{2}.[x] = R_Ltk.Red_O.h2m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h2m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => (x.`3 \in R_Ltk.Red_O.servers{1}) => x.`4 \in R_Ltk.Red_O.m1_set{1}
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists j, (j \in O_CDH.y_map{1}) /\ x.`5 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`1 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h2m_opt{1} /\ Game5Ltk.h2m{2}.[x] = R_Ltk.Red_O.h2m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h2m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => (x.`3 \in R_Ltk.Red_O.servers{1}) => ! ((x{2}.`4 \notin Game5Ltk.m1_set{2}) /\ (x{2}.`5 \in Game5Ltk.m2_set{2}) /\ (x{2}.`5 \notin R_Ltk.Red_O.servers{1}))
              => (exists j, (j \in O_CDH.y_map{1}) /\ x.`3 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`2 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => !(exists i, i \in O_CDH.x_map{1} /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] /\ x.`1 = x.`5 ^ oget O_CDH.x_map{1}.[i]) 
              => !(exists j, (j \in O_CDH.y_map{1}) /\ x.`5 = g ^ oget O_CDH.y_map{1}.[j] /\ x.`1 = x.`4 ^ oget O_CDH.y_map{1}.[j]) 
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h2m_opt{1} /\ Game5Ltk.h2m{2}.[x] = R_Ltk.Red_O.h2m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])
         /\ (forall x, x \in Game5Ltk.h2m{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2}
              => x.`3 \notin R_Ltk.Red_O.servers{1}
              => (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h2m_opt{1} /\ Game5Ltk.h2m{2}.[x] = R_Ltk.Red_O.h2m_opt{1}.[(Some x.`1, Some x.`2, x.`3, x.`4, x.`5)])

         /\ (forall b x y, (None, None, b, x, y) \in R_Ltk.Red_O.h1m_opt{1} => (x ^ (loge y), x ^ (loge b), b, x, y) \in Game5Ltk.h1m{2}
                      /\ R_Ltk.Red_O.h1m_opt{1}.[(None, None, b, x, y)] = Game5Ltk.h1m{2}.[(x ^ (loge y), x ^ (loge b), b, x, y)])
         /\ (forall xy b x y, (Some xy, None, b, x, y) \in R_Ltk.Red_O.h1m_opt{1} => (xy, x ^ (loge b), b, x, y) \in Game5Ltk.h1m{2})
         /\ (forall (x : group * group * group * group * group), (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h1m_opt{1} => x \in Game5Ltk.h1m{2})
         /\ (forall b x y, (None, None, b, x, y) \in R_Ltk.Red_O.h2m_opt{1} => (x ^ (loge y), x ^ (loge b), b, x, y) \in Game5Ltk.h2m{2}
                      /\ R_Ltk.Red_O.h2m_opt{1}.[(None, None, b, x, y)] = Game5Ltk.h2m{2}.[(x ^ (loge y), x ^ (loge b), b, x, y)])
         /\ (forall xy b x y, (Some xy, None, b, x, y) \in R_Ltk.Red_O.h2m_opt{1} => (xy, x ^ (loge b), b, x, y) \in Game5Ltk.h2m{2})
         /\ (forall (x : group * group * group * group * group), (Some x.`1, Some x.`2, x.`3, x.`4, x.`5) \in R_Ltk.Red_O.h2m_opt{1} => x \in Game5Ltk.h2m{2})

         /\ (Game5Ltk.tq{2} <> None => oget Game5Ltk.tq{2} \in Game5Ltk.hq{2} => O_CDH.win{1})

         /\ (forall pk, omap s_clear_sk Game5Ltk.servers{2}.[pk] = R_Ltk.Red_O.servers{1}.[pk])
         /\ (forall bj, omap s_clear_ltsk Game5Ltk.s_smap{2}.[bj] = R_Ltk.Red_O.s_smap{1}.[bj])
         /\ (forall i, omap c_clear_esk Game5Ltk.c_smap{2}.[i] = R_Ltk.Red_O.c_smap{1}.[i])

         (* more relational stuff for tq and hq *)
         /\ (forall x i, Game5Ltk.tq{2} = Some x => (x.`3 \in R_Ltk.Red_O.servers{1})
                     /\ x \in Game5Ltk.h2m{2}
                     /\ (i \in O_CDH.x_map{1} => x.`4 = g ^ oget O_CDH.x_map{1}.[i] => i \notin O_CDH.cr1{1})
                     /\ (exists (i j : int), (i \in O_CDH.x_map{1}) /\ x.`4 = g ^ oget O_CDH.x_map{1}.[i] 
                               /\ x.`1 = x{2}.`5 ^ oget O_CDH.x_map{1}.[i] /\ x.`2 = x{2}.`3 ^ oget O_CDH.x_map{1}.[i]
                               /\ j \in O_CDH.y_map{1} /\ x.`3 = g ^ oget O_CDH.y_map{1}.[j] /\ (i \notin O_CDH.cr1{1}) 
                               /\ (j \notin O_CDH.cr2{1})))
         /\ (forall x i j, x \in Game5Ltk.hq{2} => !Game5Ltk.bad1{2} => !Game5Ltk.bad2{2} => !Game5Ltk.bad3{2} => !O_CDH.win{1} => x.`3 \in R_Ltk.Red_O.servers{1}
              => i \notin O_CDH.x_map{1} \/ x.`4 <> g ^ (oget O_CDH.x_map{1}.[i]) \/ x.`2 <> x.`3 ^ (oget O_CDH.x_map{1}.[i]) 
                  \/ i \in O_CDH.cr1{1}  \/ j \notin O_CDH.y_map{1} \/ x.`3 <> g ^ (oget O_CDH.y_map{1}.[j]) \/ j \in O_CDH.cr2{1})

         (* one-sided part on the Game5Ltk side *)
         /\ (forall i st pt ir, i \in Game5Ltk.c_smap{2} => Game5Ltk.c_smap{2}.[i] = Some (Pending_mod st pt ir)
              => pt.`2 = g ^ st.`2)
         /\ (forall i st t k ir, i \in Game5Ltk.c_smap{2} => Game5Ltk.c_smap{2}.[i] = Some (Accepted_mod st t k ir)
              => t.`1.`2 = g ^ st.`2
                      /\ t.`2 <> None /\ ((oget t.`2).`1 ^ st.`2, st.`1 ^ st.`2, st.`1, g ^ st.`2, (oget t.`2).`1) \in Game5Ltk.h1m{2}
                      /\ (oget t.`2).`2 = oget Game5Ltk.h1m{2}.[((oget t.`2).`1 ^ st.`2, st.`1 ^ st.`2, st.`1, g ^ st.`2, (oget t.`2).`1)]
                      /\ (!ir.`1 /\ !ir.`4 /\ !(exists bj, bj \in Game5Ltk.s_smap{2} /\ get_trace (oget Game5Ltk.s_smap{2}.[bj]) = Some t) => Game5Ltk.comp_tag{2}))
         /\ (forall bj st t k ir, bj \in Game5Ltk.s_smap{2} => Game5Ltk.s_smap{2}.[bj] = Some (Accepted_mod st t k ir)
              => t.`1.`1 = g ^ st.`1
                      /\ ((t.`1).`2 ^ (oget st.`2), (t.`1).`2 ^ st.`1, g ^ st.`1, (t.`1).`2, g ^ (oget st.`2)) \in Game5Ltk.h1m{2}
                      /\ (oget t.`2).`2 = oget Game5Ltk.h1m{2}.[((t.`1).`2 ^ (oget st.`2), (t.`1).`2 ^ st.`1, g ^ st.`1, (t.`1).`2, g ^ (oget st.`2))])
         /\ (forall b sk, b \in Game5Ltk.servers => obind get_skey Game5Ltk.servers.[b] = Some sk
              => b = g ^ sk){2}
         /\ (forall x, x \in Game5Ltk.h2m{2} => x \in Game5Ltk.h1m{2})
         /\ (forall x y b, Game5Ltk.tq = Some (g ^ (ZModE.( * ) x y), g ^ (ZModE.( * ) x b), g ^ b, g ^ x, g ^ y) 
              => ((exists i tag key ir, i \in Game5Ltk.c_smap /\ Game5Ltk.c_smap.[i] 
                     = Some (Accepted_mod (g ^ b, x) ((g ^ b, g ^ x), Some (g ^ y, tag)) key ir)
                     /\ get_ir_test (oget Game5Ltk.c_smap.[i]))
                  \/ (exists i tag key ir, i \in Game5Ltk.s_smap /\ Game5Ltk.s_smap.[i] 
                       = Some (Accepted_mod (b, Some y) ((g ^ b, g ^ x), Some (g ^ y, tag)) key ir)
                     /\ get_ir_test (oget Game5Ltk.s_smap.[i])))){2}
         /\ (forall x, x \in Game5Ltk.hq => (x.`3 \in Game5Ltk.pk_set \/ x.`3 \in Game5Ltk.b_set) 
              /\ (x.`4 \in Game5Ltk.m1_set \/ (x.`4 \in Game5Ltk.x_set)) /\ (x.`5 \in Game5Ltk.y_set \/ x.`5 \in Game5Ltk.m2_set)){2}
         /\ (forall x y b, (g ^ (ZModE.( * ) x y), g ^ (ZModE.( * ) x b), g ^ b, g ^ x, g ^ y) \in Game5Ltk.h1m{2} => !Game5Ltk.bad3{2}
                => (exists i tag, i \in Game5Ltk.c_smap{2} /\ get_trace (oget Game5Ltk.c_smap{2}.[i]) = Some ((g ^ b, g ^ x), Some (g ^ y, tag)))
                  \/ (exists i tag, i \in Game5Ltk.s_smap{2} /\ get_trace (oget Game5Ltk.s_smap{2}.[i]) = Some ((g ^ b, g ^ x), Some (g ^ y, tag))
                       /\ tag = oget Game5Ltk.h1m{2}.[(g ^ (ZModE.( * ) x y), g ^ (ZModE.( * ) x b), g ^ b, g ^ x, g ^ y)])
                  \/ (g ^ (ZModE.( * ) x y), g ^ (ZModE.( * ) x b), g ^ b, g ^ x, g ^ y) \in Game5Ltk.hq{2})) R_Ltk_inv_c_test => // [/>|].
