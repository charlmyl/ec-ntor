    if => //; 2: by auto => />.
    rcondf {1} ^if. auto => />.
    rcondf {2} ^if. auto => />. 
    sp 2 2; if {2} => //.
    + auto => /> &2 *. do split; smt(get_setE mem_set).
    auto => |> &2 20? + ? _ _ _ _. 
    rewrite !negb_or negb_and.
    move => [#] ? [] ? ?.
    + do split; smt(get_setE mem_set).
    do split; smt(get_setE mem_set).
