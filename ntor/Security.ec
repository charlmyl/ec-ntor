      have->: Game5Eph.c_smap{2}.[i{2}] <> None /\ get_trace (oget Game5Eph.c_smap{2}.[i{2}]) = Some ((t{2}.`1.`1, t{2}.`1.`2), t{2}.`2) by smt().
      have pteq : (oget (get_trace (oget Game5Eph.s_smap{2}.[i2.`1, i2.`2]))).`1 = (x.`3, x.`4) by smt().
      have->: t{2}.`1.`2 = x.`4 by smt().
